# ═══════════════════════════════════════════════════════════════════════════
# SC-CraftX Configuration
# Скопируй этот файл в .env и заполни свои данные
# ═══════════════════════════════════════════════════════════════════════════

# ── Stalcraft API Credentials (ОБЯЗАТЕЛЬНО!) ────────────────────────────────
# Получить на: https://exbo.net/oauth/applications
STALCRAFT_CLIENT_ID=961
STALCRAFT_CLIENT_SECRET=ycxFtFsHsr0TPWoZrEJhmMDsuXclsNuOahxhsuzD

# ── API Settings ───────────────────────────────────────────────────────────
STALCRAFT_API_BASE=https://eapi.stalcraft.net
STALCRAFT_REGION=ru

# ── Cache & History ────────────────────────────────────────────────────────
# Время жизни кэша цен (секунды)
CACHE_TTL=180

# Сколько часов хранить историю цен
HISTORY_KEEP_HOURS=48

# ── Sync Settings (для API v2) ─────────────────────────────────────────────
# Интервал автообновления цен (секунды). Для реал-тайм: 30-60
SYNC_INTERVAL=45

# Максимум одновременных запросов к API
MAX_CONCURRENT_REQUESTS=3

# Минимальная пауза между запросами (секунды)
MIN_REQUEST_INTERVAL=0.4

# ── Database ───────────────────────────────────────────────────────────────
# Путь к БД (относительно папки приложения)
DB_PATH=cache.db

# ── Logging ────────────────────────────────────────────────────────────────
# Уровни: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Сохранять логи в файл?
LOG_TO_FILE=true
LOG_FILE_PATH=logs/stalcraft.log

# ── Старые настройки (для обратной совместимости) ──────────────────────────
HTTP_CONCURRENCY=6
LOTS_CONCURRENCY=2
COLLECT_WORKERS=4
COLLECT_SKIP_FRESH_SEC=300
